# Cloudflare _headers — security baseline for all routes.
# script-src keeps 'unsafe-inline' because Astro's is:inline scripts (theme,
# analytics, JSON-LD) aren't hashed by the build; the JSON-LD sink is
# unicode-escaped (SEO.astro) so a </script> breakout can't execute. Tighten to
# per-script hashes/nonces later. The LLM (NVIDIA/OpenRouter) calls are
# server-side from the Worker, so they need no browser connect-src entry.
# The adapter appends the immutable /_astro/* cache rule automatically.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn.sanity.io https://www.googletagmanager.com; connect-src 'self' https://challenges.cloudflare.com https://www.google-analytics.com; frame-src https://challenges.cloudflare.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: geolocation=(), microphone=(), camera=()
