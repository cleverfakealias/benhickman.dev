{
  "name": "benhickman-dev-astro",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "benhickman.dev — Astro 7 on Cloudflare Workers (Obsidian Foundry rebuild)",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "setup:local": "node scripts/setup-local.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && wrangler dev -c dist/server/wrangler.json --env-file .dev.vars",
    "check": "astro check",
    "typecheck": "astro check",
    "lint": "biome lint --files-ignore-unknown=true src scripts astro.config.mjs vitest.config.ts",
    "lint:fix": "biome lint --write --files-ignore-unknown=true src scripts astro.config.mjs vitest.config.ts",
    "test": "vitest run",
    "verify": "npm run lint && npm run check && npm test && npm run build",
    "deploy": "astro build && wrangler deploy -c dist/server/wrangler.json",
    "cf-typegen": "wrangler types",
    "postinstall": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.0.1",
    "@astrojs/react": "6.0.0",
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource/geist-sans": "5.2.5",
    "@nanostores/react": "1.1.0",
    "@sanity/client": "7.23.0",
    "@sanity/image-url": "2.1.1",
    "astro": "7.0.3",
    "astro-portabletext": "0.13.0",
    "langfuse": "^3.38.20",
    "nanostores": "1.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.5.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "happy-dom": "20.10.6",
    "typescript": "5.9.3",
    "vitest": "4.1.9",
    "wrangler": "^4.106.0"
  },
  "overrides": {
    "yaml": ">=2.8.3"
  }
}
