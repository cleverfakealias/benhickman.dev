---
import { bottomNavItems, isActive } from '@/config/navLinks';

const pathname = Astro.url.pathname;
// Split items around the elevated center "Ask" button: Home · Work · [Ask] · Writing · Contact.
const left = bottomNavItems.slice(0, 2);
const right = bottomNavItems.slice(2);
---

<nav class="bottom-nav" aria-label="Primary">
  <ul>
    {
      left.map((item) => {
        const active = isActive(item.href, pathname);
        return (
          <li>
            <a href={item.href} class:list={['tab', { active }]} aria-current={active ? 'page' : undefined}>
              <span class="tab-icon" aria-hidden="true">{item.icon}</span>
              <span class="tab-label">{item.name}</span>
            </a>
          </li>
        );
      })
    }

    <li class="ask-slot">
      <!-- ⌘K trigger — links to /contact as the no-JS fallback (Phase 5 palette
           intercepts [data-cmdk-trigger]). -->
      <a href="/contact" class="ask-button" data-cmdk-trigger aria-label="Ask my work">
        <span class="ask-glyph" aria-hidden="true">⌘</span>
        <span class="tab-label">Ask</span>
      </a>
    </li>

    {
      right.map((item) => {
        const active = isActive(item.href, pathname);
        return (
          <li>
            <a href={item.href} class:list={['tab', { active }]} aria-current={active ? 'page' : undefined}>
              <span class="tab-icon" aria-hidden="true">{item.icon}</span>
              <span class="tab-label">{item.name}</span>
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 60;
    background: color-mix(in oklch, var(--color-surface) 96%, transparent);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--color-border);
    padding-bottom: env(safe-area-inset-bottom);
  }
  .bottom-nav ul {
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    list-style: none;
    margin: 0;
    padding: 0;
    height: var(--bottom-nav-h);
  }
  .bottom-nav li {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .tab {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    width: 100%;
    min-height: 56px;
    padding: var(--space-2) 0;
    border-bottom: none;
    color: var(--color-text-secondary);
    transition: color var(--motion-150) var(--easing-standard);
  }
  .tab:hover,
  .tab.active {
    color: var(--color-text);
    border-bottom: none;
  }
  .tab.active::before {
    content: '';
    position: absolute;
    top: 0;
    left: 25%;
    right: 25%;
    height: 2px;
    background: var(--color-accent-hex);
    border-radius: 0 0 2px 2px;
  }
  .tab.active .tab-icon {
    color: var(--color-accent-hex);
  }
  .tab-icon {
    font-family: var(--font-mono);
    font-size: 19px;
    line-height: 1;
  }
  .tab-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.02em;
  }

  .ask-slot {
    flex: 0 0 auto;
  }
  .ask-button {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    width: 46px;
    height: 46px;
    margin-top: -22px;
    border-radius: var(--radius-pill);
    border: 4px solid var(--color-bg);
    border-bottom: 4px solid var(--color-bg);
    background: var(--color-accent-fill);
    color: var(--color-accent-contrast-hex);
    transition: background var(--motion-150) var(--easing-standard);
  }
  .ask-button:hover {
    background: var(--color-accent-fill-hover);
    border-bottom: 4px solid var(--color-bg);
  }
  .ask-button .tab-label {
    font-size: 9px;
    color: var(--color-accent-contrast-hex);
  }
  .ask-glyph {
    font-size: 20px;
    line-height: 1;
  }

  /* Desktop: the header pill is the Primary landmark — remove this from the
     a11y tree above the mobile breakpoint. */
  @media (min-width: 768px) {
    .bottom-nav {
      display: none;
    }
  }
</style>
