---
// Link mark serializer. astro-portabletext passes the mark as `node`; the link
// fields live on `node.markDef`, and the link text comes through the slot.
import type { MarkProps } from 'astro-portabletext/types';

type Props = MarkProps<{ href?: string }>;
const { node } = Astro.props;
const raw = node.markDef?.href ?? '#';
// Scheme allowlist — neutralize javascript:/data: and other XSS vectors from CMS links.
// Protocol-relative forms (//host, and /\host which browsers normalize to //host)
// must be rejected before the allowlist: they start with "/" but navigate
// off-site, dodging the external-link classification below.
const href = /^[/\\]{2}/.test(raw) || !/^(https?:|mailto:|tel:|\/|#)/i.test(raw) ? '#' : raw;
const external = /^https?:\/\//.test(href);
---

<a
  href={href}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <slot />
</a>
