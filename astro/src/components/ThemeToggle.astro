---
// Pure-markup toggle. The actual flip + persistence is handled once, globally,
// by the inline theme script in BaseLayout via `[data-theme-toggle]` click
// delegation (survives view transitions, no per-instance JS). Which icon shows
// is pure CSS off html[data-theme] — so it's correct pre-paint, no FOUC flicker.
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<!-- aria-pressed: "true" = light theme engaged (dark is the site default, so the
     server renders "false"); the BaseLayout theme script syncs it on load and on
     every toggle, keeping SR output truthful for visitors who saved "light". -->
<button
  type="button"
  data-theme-toggle
  class:list={['theme-toggle', className]}
  aria-pressed="false"
  aria-label="Toggle colour theme"
  title="Toggle colour theme"
>
  <svg class="icon icon-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <circle cx="12" cy="12" r="4.5" fill="currentColor"></circle>
    <g stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
      <line x1="12" y1="2" x2="12" y2="4.5"></line>
      <line x1="12" y1="19.5" x2="12" y2="22"></line>
      <line x1="2" y1="12" x2="4.5" y2="12"></line>
      <line x1="19.5" y1="12" x2="22" y2="12"></line>
      <line x1="4.9" y1="4.9" x2="6.7" y2="6.7"></line>
      <line x1="17.3" y1="17.3" x2="19.1" y2="19.1"></line>
      <line x1="4.9" y1="19.1" x2="6.7" y2="17.3"></line>
      <line x1="17.3" y1="6.7" x2="19.1" y2="4.9"></line>
    </g>
  </svg>
  <svg class="icon icon-moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path
      d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"
      fill="currentColor"
    ></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition:
      color var(--motion-150) var(--easing-standard),
      border-color var(--motion-150) var(--easing-standard),
      background var(--motion-150) var(--easing-standard);
  }
  .theme-toggle:hover {
    color: var(--color-accent-hex);
    border-color: var(--color-border);
    background: color-mix(in oklch, var(--color-accent) 8%, transparent);
  }
  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent-hex);
    outline-offset: 2px;
  }
  /* Show the icon for the action the click performs: dark theme → show sun
     (switch to light); light theme → show moon. */
  .icon {
    display: none;
  }
  :global(html[data-theme='dark']) .icon-sun {
    display: block;
  }
  :global(html[data-theme='light']) .icon-moon {
    display: block;
  }
  /* Fallback before JS sets data-theme: assume dark default → show sun. */
  :global(html:not([data-theme='light'])) .icon-sun {
    display: block;
  }
</style>
