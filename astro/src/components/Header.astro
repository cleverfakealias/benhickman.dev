---
import { navLinks, isActive } from '@/config/navLinks';
import { site } from '@/config/site';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="pill">
    <a href="/" class="brand" aria-label={`${site.name} — home`}>
      <span class="brand-mark" aria-hidden="true">{site.mark}</span>
      <span class="brand-name">{site.name}</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {
          navLinks.map((link) => {
            const active = isActive(link.href, pathname);
            return (
              <li>
                <a href={link.href} class:list={['nav-link', { active }]} aria-current={active ? 'page' : undefined}>
                  {link.name}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="actions">
      <!-- ⌘K "ask my work" — links to /contact as the no-JS fallback; the
           CommandPalette island (Phase 5) intercepts [data-cmdk-trigger] clicks. -->
      <a href="/contact" class="ask" data-cmdk-trigger aria-label="Ask my work — open command bar">
        <span class="ask-label">ask my work</span>
        <kbd class="kbd">⌘K</kbd>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
    padding-top: max(var(--space-3), env(safe-area-inset-top));
  }
  .pill {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    max-width: 1100px;
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-4);
    background: color-mix(in oklch, var(--color-surface) 92%, transparent);
    -webkit-backdrop-filter: saturate(1.4);
    backdrop-filter: saturate(1.4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    border-bottom: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    white-space: nowrap;
  }
  .brand:hover {
    border-bottom: none;
  }
  .brand-mark {
    color: var(--color-accent-hex);
    font-size: 1.1rem;
    line-height: 1;
  }

  .primary-nav {
    margin-inline: auto;
  }
  .primary-nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    position: relative;
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    border-bottom: none;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    transition:
      color var(--motion-150) var(--easing-standard),
      background var(--motion-150) var(--easing-standard);
  }
  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface-2);
    border-bottom: none;
  }
  .nav-link.active {
    color: var(--color-text);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: var(--space-3);
    right: var(--space-3);
    bottom: 4px;
    height: 2px;
    background: var(--color-accent-hex);
    border-radius: 2px;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .ask {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    white-space: nowrap;
    transition:
      color var(--motion-150) var(--easing-standard),
      border-color var(--motion-150) var(--easing-standard),
      background var(--motion-150) var(--easing-standard);
  }
  .ask:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
    background: var(--color-surface-2);
  }
  .kbd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px 5px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    background: var(--color-bg);
  }

  /* Mobile: the bottom tab bar is the Primary landmark instead — hide this nav
     and the ask pill entirely (removed from the a11y tree, so exactly one
     Primary nav is exposed per breakpoint). */
  @media (max-width: 767px) {
    .primary-nav,
    .ask {
      display: none;
    }
    .brand-name {
      display: inline;
    }
    .pill {
      justify-content: space-between;
    }
  }
</style>
