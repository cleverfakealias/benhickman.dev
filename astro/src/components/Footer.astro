---
import { navLinks } from '@/config/navLinks';
import { site } from '@/config/site';
import Socials from './Socials.astro';
import ThemeToggle from './ThemeToggle.astro';

const year = new Date().getFullYear();
const quickLinks = [...navLinks, { name: 'Privacy', href: '/privacy' }];
---

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-meta">
      <p class="copyright">© {year} {site.name} · built in an IDE</p>
      <p class="decoration" aria-hidden="true">
        <span class="brand-mark">{site.mark}</span> model → agent → UI
      </p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <ul>
        {quickLinks.map((link) => (
          <li><a href={link.href}>{link.name}</a></li>
        ))}
        <li>
          <button type="button" class="link-button" data-consent-settings>Cookie Preferences</button>
        </li>
      </ul>
    </nav>

    <div class="footer-actions">
      <Socials />
      <ThemeToggle />
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-7);
    /* Clear the fixed mobile bottom bar; flat on desktop. */
    padding-bottom: calc(var(--bottom-nav-h) + env(safe-area-inset-bottom));
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-5);
  }
  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .copyright,
  .decoration {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    margin: 0;
  }
  .copyright {
    font-size: 0.75rem;
  }
  .decoration {
    font-size: 0.7rem;
  }
  .decoration .brand-mark {
    color: var(--color-accent-hex);
  }

  .footer-links ul {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-links a,
  .link-button {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid transparent;
  }
  .footer-links a:hover {
    color: var(--color-accent-hex);
  }
  .link-button {
    background: none;
    border: none;
    border-bottom: 1px solid transparent;
    padding: 0;
    cursor: pointer;
  }
  .link-button:hover {
    color: var(--color-accent-hex);
  }

  .footer-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  @media (max-width: 767px) {
    .decoration {
      display: none;
    }
  }
  @media (min-width: 768px) {
    .site-footer {
      padding-bottom: 0;
    }
  }
</style>
