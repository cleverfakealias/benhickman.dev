---
import { site } from '@/config/site';

interface Props {
  title?: string;
  description?: string;
  /** Canonical path (defaults to the current route). */
  path?: string;
  /** OG/Twitter image path or absolute URL. */
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  noindex?: boolean;
  /** Extra JSON-LD object(s) to emit (e.g. Article, BreadcrumbList). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = site.description,
  path,
  image = site.ogImage,
  type = 'website',
  publishedTime,
  noindex = false,
  jsonLd,
} = Astro.props;

const fullTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.tagline}`;
const canonical = new URL(path ?? Astro.url.pathname, site.url).href;
const ogImage = new URL(image, site.url).href;

// Person (site identity) + WebSite — emitted on every page.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: site.url,
  jobTitle: 'AI/ML Engineer',
  description: site.description,
  image: new URL(site.ogImage, site.url).href,
  sameAs: ['https://github.benhickman.dev', 'https://linkedin.benhickman.dev'],
};
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.description,
};
const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const graphs = [personLd, websiteLd, ...extraLd];
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{
  graphs.map((g) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(g)} />
  ))
}
