---
import { stackGroups } from '@/data/homeContent';
import SectionHeading from './SectionHeading.astro';
---

<section class="stack" aria-labelledby="stack-heading">
  <div class="wrap">
    <SectionHeading id="stack-heading" eyebrow="// stack" title="The whole depth of the stack." />
    {
      stackGroups.map((g) => (
        <div class="row">
          <p class="label">{g.label}</p>
          <div class="items">
            {g.items.map((item) => <span class="item">{item}</span>)}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .stack {
    padding-bottom: clamp(64px, 9vw, 112px);
  }
  .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    align-items: start;
    padding-block: 18px;
    border-top: 1px solid var(--color-border);
  }
  .row:first-of-type {
    border-top: none;
  }
  .label {
    margin: 0;
    padding-top: 5px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .item {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 6px 11px;
    background: var(--color-surface);
  }
  @media (min-width: 600px) {
    .row {
      grid-template-columns: 120px 1fr;
      gap: 18px;
    }
  }
</style>
