---
import { socials, CONTACT_HREF } from '@/data/homeContent';
import SectionHeading from './SectionHeading.astro';
---

<section class="contact section-y" aria-labelledby="contact-heading">
  <div class="wrap inner">
    <SectionHeading
      id="contact-heading"
      centered
      eyebrow="// contact"
      title="Ready to build agents that think?"
      titleHtml="Ready to build agents that <em>think?</em>"
    />
    <p class="desc">
      Tell me about the system — what it should do, where it runs, and what "good" looks like. I read
      every message.
    </p>
    <div class="cta-row">
      <a class="button-primary cta" href={CONTACT_HREF}>Start a conversation</a>
    </div>
    <div class="socials">
      {
        socials.map((s) => (
          <a href={s.href} target="_blank" rel="me noopener noreferrer">
            {s.name} <span class="arrow" aria-hidden="true">↗</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .inner {
    text-align: center;
  }
  .desc {
    margin: 9px auto 0;
    max-width: 520px;
    color: var(--color-text-secondary);
  }
  .cta-row {
    margin-top: 14px;
    display: flex;
    justify-content: center;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 44px;
    padding: 13px 20px;
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    border: 1px solid transparent;
  }
  .socials {
    margin-top: 15px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    padding: 9px 16px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    transition:
      color 180ms var(--easing-standard),
      border-color 180ms var(--easing-standard),
      background 180ms var(--easing-standard);
  }
  .socials a:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
    border-bottom-color: var(--color-border-hover);
    background: var(--color-surface);
  }
  .socials .arrow {
    color: var(--color-accent-hex);
  }
</style>
