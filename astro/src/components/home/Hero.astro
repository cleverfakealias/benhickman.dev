---
import { CMDK_PLACEHOLDER, WORK_HREF, CONTACT_HREF } from '@/data/homeContent';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="wrap inner">
    <p class="eyebrow">// agentic engineering <span class="accent">&gt;</span><span class="cursor">_</span></p>

    <!-- ⌘K trigger — links to /contact as the no-JS fallback (Phase 5 palette intercepts). -->
    <a href={CONTACT_HREF} class="cmdk" data-cmdk-trigger aria-label="Ask my work — command menu">
      <span class="cmdk-key">⌘K</span>
      <span class="cmdk-placeholder">{CMDK_PLACEHOLDER}<span class="cursor">_</span></span>
      <kbd class="kbd">↵</kbd>
    </a>

    <h1 id="hero-heading">Agents that <em>ship,</em><br />built from the model up.</h1>

    <p class="lede">
      I build production agentic systems — tool-calling, permission tiers, confidence gating — then
      go a layer deeper: training, fine-tuning, and right-sizing the models they run on.
      Enterprise-tested. Self-hostable, end to end.
    </p>

    <div class="availability">
      <span class="status"><span class="dot"></span> open to senior AI roles</span>
      <span class="sep">·</span>
      <span>select consulting</span>
      <span class="sep">·</span>
      <span>remote</span>
      <span class="sep">·</span>
      <span>full-stack AI</span>
    </div>

    <div class="ctas">
      <a class="button-primary cta" href={CONTACT_HREF}>Start a conversation</a>
      <a class="cta ghost" href={WORK_HREF}>See the work →</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(56px, 9vh, 112px);
    padding-bottom: clamp(64px, 9vw, 112px);
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: min(900px, 120%);
    height: 600px;
    background: radial-gradient(closest-side, rgba(230, 81, 0, 0.08), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .inner {
    position: relative;
    z-index: 1;
    max-width: 920px;
  }
  .eyebrow .accent {
    color: var(--color-accent-hex);
  }
  .cursor {
    color: var(--color-accent-hex);
    /* `blink` is the global keyframes in global.css (shared with .cmdk-cursor) —
       not redefined here, so Astro leaves the name unscoped. */
    animation: blink 1.1s steps(1) infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }

  .cmdk {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    max-width: 560px;
    margin-top: 22px;
    margin-bottom: 30px;
    padding: 15px 16px;
    text-align: left;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-secondary);
    transition:
      border-color 180ms var(--easing-standard),
      background 180ms var(--easing-standard);
  }
  .cmdk:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface-2);
    border-bottom-color: var(--color-border-hover);
  }
  .cmdk-key {
    color: var(--color-accent-hex);
    font-family: var(--font-mono);
    font-size: 15px;
  }
  .cmdk-placeholder {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .kbd {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.4;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    padding: 1px 6px;
    color: var(--color-text-secondary);
  }

  h1 {
    font-size: clamp(2.75rem, 9vw, 5.5rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 0;
  }
  h1 em {
    font-style: italic;
    font-family: var(--font-display), serif;
    color: var(--color-accent-hex);
  }
  .lede {
    margin-top: var(--space-3);
    max-width: 620px;
    font-size: clamp(16px, 2.4vw, 20px);
    line-height: 1.62;
    color: var(--color-text-secondary);
  }
  .availability {
    margin-top: 14px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 14px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--color-text-secondary);
  }
  .status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent-hex);
    box-shadow: 0 0 0 4px rgba(230, 81, 0, 0.14);
  }
  .sep {
    color: var(--color-text-muted);
  }
  .ctas {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .cta.ghost {
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .cta.ghost:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface);
    border-bottom-color: var(--color-border-hover);
  }
</style>
