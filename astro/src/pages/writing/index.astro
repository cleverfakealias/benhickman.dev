---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { getAllPosts, responsiveImageAttrs, formatDate } from '@/lib/sanity';

const posts = await getAllPosts();
---

<BaseLayout
  title="Writing"
  description="Notes from the stack — agents, RAG, local models, and engineering."
>
  <section class="wrap section-y">
    <PageHeader
      class="head"
      eyebrow="// writing"
      title="Notes from the stack."
      lede="Working notes on agents, retrieval, local models, and shipping software with AI in the loop."
    />

    {
      posts.length === 0 ? (
        <p class="empty">No posts published yet — check back soon.</p>
      ) : (
        <ul class="grid">
          {posts.map((post) => {
            const cover = post.mainImage?.asset
              ? responsiveImageAttrs(post.mainImage, { baseWidth: 800, aspectRatio: 2 })
              : null;
            return (
              <li>
                <a href={`/writing/${post.slug}`} class="card">
                  {cover && (
                    <img
                      class="cover"
                      src={cover.src}
                      srcset={cover.srcset}
                      sizes="(min-width: 980px) 370px, (min-width: 640px) 50vw, 100vw"
                      alt={post.mainImage?.alt ?? ''}
                      loading="lazy"
                      width="800"
                      height="400"
                    />
                  )}
                  <div class="body">
                    <p class="meta">
                      <span>{formatDate(post.publishedAt)}</span>
                      {post.estimatedReadingTime ? <span>· {post.estimatedReadingTime} min read</span> : null}
                    </p>
                    <h2>{post.title}</h2>
                    {post.excerpt && <p class="excerpt">{post.excerpt}</p>}
                    <span class="readcta">read →</span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  .head {
    max-width: 680px;
    margin-bottom: var(--space-6);
    --lede-max: 60ch;
  }
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    background: var(--color-surface);
    transition:
      border-color 200ms var(--easing-standard),
      transform 200ms var(--easing-standard);
  }
  .card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .card:hover {
      transform: none;
    }
  }
  .cover {
    width: 100%;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    border-bottom: 1px solid var(--color-border);
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--pad-card);
    flex: 1;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .body h2 {
    font-size: 1.2rem;
    line-height: 1.3;
    margin: 0;
    color: var(--color-text);
  }
  .excerpt {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .empty {
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }
  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 980px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
