---
export const prerender = true;

import { PortableText } from 'astro-portabletext';
import type { PortableTextComponents } from 'astro-portabletext/types';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SanityImage from '@/components/portable/SanityImage.astro';
import CodeBlock from '@/components/portable/CodeBlock.astro';
import PortableLink from '@/components/portable/Link.astro';
import { getAllPostSlugs, getPostBySlug, urlForImage, formatDate } from '@/lib/sanity';
import { site } from '@/config/site';

export async function getStaticPaths() {
  const slugs = await getAllPostSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);
if (!post) return Astro.redirect('/404');

const cover = post.mainImage?.asset
  ? urlForImage(post.mainImage).width(1200).height(600).fit('crop').url()
  : null;

const ptComponents: Partial<PortableTextComponents> = {
  type: { image: SanityImage, code: CodeBlock },
  mark: { link: PortableLink },
};

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  datePublished: post.publishedAt,
  author: { '@type': 'Person', name: post.author ?? site.name },
  ...(cover ? { image: cover } : {}),
  mainEntityOfPage: `${site.url}/writing/${post.slug}`,
};
---

<BaseLayout
  title={post.title}
  description={post.excerpt ?? site.description}
  type="article"
  image={cover ?? site.ogImage}
  publishedTime={post.publishedAt}
  jsonLd={articleLd}
>
  <article class="post">
    <div class="wrap">
      <a class="back" href="/writing">← All writing</a>
      <p class="meta">
        <span>{formatDate(post.publishedAt)}</span>
        {post.estimatedReadingTime ? <span>· {post.estimatedReadingTime} min read</span> : null}
        {post.author ? <span>· {post.author}</span> : null}
      </p>
      <h1>{post.title}</h1>
    </div>

    {
      cover && (
        <div class="wrap">
          <img class="cover" src={cover} alt={post.mainImage?.alt ?? ''} width="1200" height="600" />
        </div>
      )
    }

    <div class="wrap prose">
      {post.body ? <PortableText value={post.body} components={ptComponents} /> : <p>No content.</p>}
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding-block: var(--space-6) var(--space-7);
  }
  .back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }
  .post h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 18ch;
  }
  .cover {
    width: 100%;
    height: auto;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-top: var(--space-5);
  }

  /* Prose — the rendered Portable Text body. Constrained measure for reading. */
  .prose {
    max-width: 720px;
    margin-top: var(--space-6);
  }
  .prose :global(p) {
    margin-block: var(--space-4);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .prose :global(h2) {
    font-size: 1.6rem;
    margin-block: var(--space-6) var(--space-3);
    letter-spacing: -0.01em;
  }
  .prose :global(h3) {
    font-size: 1.25rem;
    margin-block: var(--space-5) var(--space-2);
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-block: var(--space-4);
    padding-left: var(--space-5);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .prose :global(li) {
    margin-block: var(--space-1);
  }
  .prose :global(blockquote) {
    margin: var(--space-5) 0;
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-accent-hex);
    color: var(--color-text);
    font-style: italic;
  }
  .prose :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    padding: 2px 6px;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }
  .prose :global(a) {
    color: var(--color-accent-hex);
    border-bottom: 1px solid transparent;
  }
  .prose :global(a:hover) {
    border-bottom-color: currentColor;
  }
</style>
